{
  "name": "kio-dev",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "scripts": {
    "build": "pnpm subset-fonts && vite build --mode production",
    "dev": "pnpm subset-fonts && vite dev --mode development --host",
    "package": "svelte-kit package",
    "preview": "vite preview",
    "coverage": "vitest run --coverage",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write ./src/**/*.{ts,svelte}",
    "lint": "pnpm format && pnpm eslint --fix \"./src/**/*.{ts,svelte}\" \"./types/**/*.ts\"",
    "lint:check": "pnpm prettier --check ./src/**/*.{ts,svelte} && pnpm eslint \"./src/**/*.{ts,svelte}\" \"./types/**/*.ts\"",
    "subset-fonts": "node ./scripts/subset-fonts.ts",
    "prepare": "test -f ./.husky/pre-commit || (husky install && chmod ug+x ./.husky/* && husky add ./.husky/pre-commit 'pnpm lint-staged')"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@stylistic/eslint-plugin": "^5.7.0",
    "@sveltejs/adapter-netlify": "5.0.2",
    "@sveltejs/adapter-node": "5.2.12",
    "@sveltejs/kit": "^2.49.5",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@tailwindcss/postcss": "^4.1.10",
    "@tailwindcss/vite": "^4.1.18",
    "@types/js-yaml": "^4.0.9",
    "@types/subset-font": "^2.3.0",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.5.0",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-local-rules": "^3.0.2",
    "eslint-plugin-prettier": "^5.5.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-svelte": "^3.9.3",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.6",
    "js-yaml": "^4.1.1",
    "jsdom": "^24.1.0",
    "lint-staged": "^16.2.7",
    "mdsvex": "^0.12.7",
    "netlify-cli": "^22.1.6",
    "postcss": "^8.5.6",
    "postcss-load-config": "^5.1.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "rehype-autolink-headings": "^6",
    "rehype-external-links": "^3.0.0",
    "rehype-slug": "^5",
    "shiki": "^4.0.2",
    "subset-font": "^2.5.0",
    "svelte": "^5.34.8",
    "svelte-check": "^3.7.1",
    "svelte-eslint-parser": "^1.2.0",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vite": "^7.3.1",
    "vite-plugin-inspect": "^11.2.0",
    "vitest": "^3.2.4"
  }
}
